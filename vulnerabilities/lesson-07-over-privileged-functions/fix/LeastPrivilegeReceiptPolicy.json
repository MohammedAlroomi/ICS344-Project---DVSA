{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReceiptsBucketOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::*dvsa*receipts*/*"
    },
    {
      "Sid": "DynamoDBOrdersTableOnly",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:915204716365:table/DVSA-ORDERS-DB"
    },
    {
      "Sid": "SESSendOnly",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*"
    }
  ]
}
